/v1776396453/plants/ryor07ya6gy8n7u3bnix.webp","name":"Lemon","price":90,"type":"regular tree","updatedAt":"2026-04-17T03:27:34.014Z"},{"__v":0,"_id":"69e115fa9a66fe21deb31f4f","care":"Neem trees grow fast. Prune the tip of the main stem if you want to encourage a bushier","createdAt":"2026-04-16T17:01:46.907Z","description":"Neem is essentially the \"Swiss Army Knife\" of the plant world, especially in India.","img":"https://res.cloudinary.com/djpl2duyj/image/upload/v1776358905/plants/uhxewdlas5yzapqbkphf.webp","name":"Neem","price":50,"type":"regular tree","updatedAt":"2026-04-16T17:01:46.907Z"},{"__v":0,"_id":"69e1110e9a66fe21deb31e32","care":"Water the peace lily adequately.","createdAt":"2026-04-16T16:40:46.063Z","description":"Peace lilies are one of the most popular varieties of houseplants.","img":"https://res.cloudinary.com/djpl2duyj/image/upload/v1776357644/plants/rjtcrzdeft9zutvhe8ts.jpg","name":"Peace lily","price":120,"type":"indoor","updatedAt":"2026-04-16T16:40:46.063Z"},{"__v":0,"_id":"69c51e6b377d24fef0ade656","care":"waters every 3 day","createdAt":"2026-03-26T11:54:19.315Z","description":"Use tall ceramic pots for corners","img":"https://res.cloudinary.com/djpl2duyj/image/upload/v1774526058/plants/jee6gvqc1eb7gsn0erph.jpg","name":"Snake Plant","price":50,"type":"outdoor","updatedAt":"2026-04-07T09:57:18.991Z"}]
